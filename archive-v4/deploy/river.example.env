# River Engine environment variables
# Copy to /etc/river/river.env (system) or ~/.config/river/river.env (user)

# Logging
RUST_LOG=info,river_orchestrator=debug,river_worker=debug

# API Keys (required)
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Discord (if using discord adapter)
DISCORD_TOKEN=...
