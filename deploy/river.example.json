{
  "port": 4000,

  "models": {
    "claude-sonnet": {
      "endpoint": "https://api.anthropic.com/v1/messages",
      "name": "claude-sonnet-4-20250514",
      "api_key": "$ANTHROPIC_API_KEY",
      "context_limit": 200000
    },
    "claude-haiku": {
      "endpoint": "https://api.anthropic.com/v1/messages",
      "name": "claude-haiku-4-20250514",
      "api_key": "$ANTHROPIC_API_KEY",
      "context_limit": 200000
    },
    "voyage-3": {
      "endpoint": "https://api.voyageai.com/v1/embeddings",
      "name": "voyage-3",
      "api_key": "$VOYAGE_API_KEY",
      "dimensions": 1024
    }
  },

  "embed": {
    "model": "voyage-3"
  },

  "dyads": {
    "river": {
      "workspace": "/var/lib/river/workspaces/river",
      "left_model": "claude-sonnet",
      "right_model": "claude-haiku",
      "left_starts_as": "actor",
      "ground": {
        "name": "Cassie",
        "id": "123456789",
        "channel": {
          "adapter": "discord",
          "id": "backchannel"
        }
      },
      "adapters": [
        {
          "type": "discord",
          "binary": "/usr/local/bin/river-discord",
          "config": {
            "token": "$DISCORD_TOKEN",
            "guild_id": "1234567890123456789"
          }
        }
      ]
    }
  }
}
